# Google Service Account credentials (paste full JSON as a single line)
SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Google Sheets
SHEET_ID=your_google_sheet_id_here
SHEET_RANGE=Sheet1!A:Z
SHEET_NAME=Sheet1

# Google Calendar
# Get this from Google Calendar > Settings > Integrate Calendar > Calendar ID
# Make sure to share the calendar with the service account's client_email (Make changes to events permission)
# Group/shared calendar format: abc123xyz@group.calendar.google.com
# Personal calendar: use your Gmail address (e.g. user@gmail.com) or 'primary'
CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Audit log sheet range
AUDIT_RANGE=AuditLog!A:E

# Server port
PORT=3001
